# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
# IntelliJ / Android Studio
frontend/*.iml
frontend/.idea/

# Flutter / Dart / Pub
frontend/**/doc/api/
